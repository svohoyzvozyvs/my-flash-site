# 创建一个简单的头部
echo '<html><head><meta charset="utf-8"><title>我的游戏库</title><style>body{font-family:sans-serif;padding:20px;background:#f0f0f0;} li{margin:5px 0;} a{text-decoration:none;color:#333;display:block;padding:5px;background:#fff;border-radius:4px;} a:hover{background:#ddd;}</style></head><body><h1>Flash 游戏库</h1><ul>' > html/index.html

# 扫描游戏目录 (注意路径匹配 docker 挂载路径)
# 这里我们利用 find 命令查找所有 swf 文件
find /root/data/docker_data/openlist/data/openlist/download/小游戏合集（未压缩） -name "*.swf" | while read filepath; do
    # 获取文件名
    filename=$(basename "$filepath")
    # 获取相对路径 (用于 web 访问)
    # 这里的 sed 是把宿主机的绝对路径替换成 web 相对路径 games/...
    relpath=$(echo "$filepath" | sed 's|/root/data/docker_data/openlist/data/openlist/download/小游戏合集（未压缩）|games|')

    # 写入 HTML 链接，指向 player.html
    echo "<li><a href='player.html?game=$relpath' target='_blank'>?? $filename</a></li>" >> html/index.html
done

# 写入尾部
echo '</ul></body></html>' >> html/index.html